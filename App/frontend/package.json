{
  "name": "db-insight-frontend",
  "version": "0.1.0",
  "description": "DB_insight — 5-domain local multimodal search (Doc/Img/Movie/Rec/BGM) with TriCHEF + CLAP. Chromaprint, BGE-M3, SigLIP2 powered.",
  "author": {
    "name": "KDT-FT-team3-Chainers",
    "url": "https://github.com/KDT-Chainers/DB_insight"
  },
  "license": "MIT",
  "homepage": "https://github.com/KDT-Chainers/DB_insight",
  "repository": {
    "type": "git",
    "url": "https://github.com/KDT-Chainers/DB_insight.git"
  },
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "prepack": "npm run build",
    "pack": "electron-builder --dir",
    "predist": "node -e \"const fs=require('fs');const {execSync}=require('child_process');try{execSync('rmdir /s /q out\\\\win-unpacked',{shell:true,stdio:'pipe'})}catch(_){}\"",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.dbinsight.app",
    "productName": "DB_insight",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "out"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "electron/preload.cjs"
    ],
    "extraResources": [],
    "win": {
      "target": "portable",
      "signingHashAlgorithms": null,
      "sign": null,
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "app-builder-bin": "^4.2.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^25.0.0",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.9",
    "vite": "^5.4.1",
    "wait-on": "^8.0.0"
  }
}
